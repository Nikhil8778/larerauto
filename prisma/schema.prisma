generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Make {
  id        String    @id @default(cuid())
  name      String    @unique
  models    Model[]
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())
}

model Model {
  id        String    @id @default(cuid())
  name      String
  makeId    String
  make      Make      @relation(fields: [makeId], references: [id], onDelete: Cascade)
  engines   Engine[]
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())

  @@unique([makeId, name])
  @@index([makeId])
}

model Engine {
  id        String    @id @default(cuid())
  name      String
  modelId   String
  model     Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())

  @@unique([modelId, name])
  @@index([modelId])
}

model Vehicle {
  id       String @id @default(cuid())
  makeId   String
  modelId  String
  engineId String
  year     Int

  make   Make   @relation(fields: [makeId], references: [id], onDelete: Cascade)
  model  Model  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  engine Engine @relation(fields: [engineId], references: [id], onDelete: Cascade)

  offers           Offer[]
  vehiclePartTypes VehiclePartType[]
  createdAt        DateTime          @default(now())

  @@unique([makeId, modelId, engineId, year])
  @@index([makeId])
  @@index([modelId])
  @@index([engineId])
  @@index([year])
  @@index([makeId, modelId, engineId, year])
}

model PartType {
  id        String            @id @default(cuid())
  name      String            @unique
  parts     Part[]
  fitments  VehiclePartType[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model VehiclePartType {
  id         String   @id @default(cuid())
  vehicleId  String
  partTypeId String
  createdAt  DateTime @default(now())

  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  partType PartType @relation(fields: [partTypeId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, partTypeId])
  @@index([vehicleId])
  @@index([partTypeId])
}

model Part {
  id          String   @id @default(cuid())
  partTypeId  String
  title       String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partType PartType @relation(fields: [partTypeId], references: [id], onDelete: Restrict)
  offers   Offer[]

  @@index([partTypeId])
}

model Offer {
  id        String @id @default(cuid())
  vehicleId String
  partId    String

  sourceId       String // internal only: "manual", "distA", "distB"
  sourceSku      String?
  inventoryQty   Int
  costPriceCents Int

  referencePriceCents Int? // final chosen vendor reference price
  sellPriceCents      Int // customer-facing item price

  amazonPriceCents   Int?
  aPremiumPriceCents Int?

  amazonUrl   String?
  aPremiumUrl String?

  syncStatus      String? // "success", "failed", "partial"
  syncError       String?
  lastPriceSyncAt DateTime?

  currency     String   @default("CAD")
  leadTimeDays Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  candidates VendorCandidate[]
  vehicle    Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  part       Part              @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([partId])
  @@index([sourceId])
  @@index([syncStatus])
}

model VendorCandidate {
  id         String   @id @default(cuid())
  offerId    String
  vendor     String // "amazon" | "apremium"
  title      String
  productUrl String
  priceCents Int?
  badge      String?
  inStock    Boolean?
  score      Int      @default(0)
  selected   Boolean  @default(false)
  rawText    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@index([vendor])
  @@index([score])
}

model Quote {
  id             String   @id @default(cuid())
  make           String
  model          String
  engine         String
  year           Int
  partType       String
  vin            String?
  bestOfferId    String?
  itemPriceCents Int
  createdAt      DateTime @default(now())
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  isActive     Boolean        @default(true)
  sessions     AdminSession[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model AdminSession {
  id         String    @id @default(cuid())
  token      String    @unique
  adminUserId String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  adminUser  AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
}

model Customer {
  id             String      @id @default(cuid())
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  whatsappNumber String?
  companyName    String?
  notes          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  province       String?
  postalCode     String?
  country        String? @default("Canada")
  isActive       Boolean     @default(true)
  orders         Order[]
  invoices       Invoice[]
  conversations  Conversation[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([email])
  @@index([phone])
  @@index([whatsappNumber])
  @@index([firstName])
  @@index([postalCode])
}

model Order {
  id                   String       @id @default(cuid())
  orderNumber          String       @unique
  customerId           String
  quoteId              String?
  status               String       @default("draft") // draft | confirmed | processing | shipped | completed | cancelled
  paymentStatus        String       @default("pending") // pending | partial | paid | refunded
  fulfillmentStatus    String       @default("unfulfilled") // unfulfilled | processing | ready | shipped | delivered
  currency             String       @default("CAD")
  subtotalCents        Int          @default(0)
  taxCents             Int          @default(0)
  shippingCents        Int          @default(0)
  discountCents        Int          @default(0)
  totalCents           Int          @default(0)
  internalNotes        String?
  customerNotes        String?
  sourceChannel        String?      // website | whatsapp | instagram | facebook | kijiji | karot | manual
  deliveryChargeCents  Int          @default(0)
  taxPercentApplied    Float        @default(13)
  paymentGateway       String?      // square | stripe
  paymentReference     String?
  paidAt               DateTime?
  billingEmail         String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  province             String?
  postalCode           String?
  country              String?      @default("Canada")
  estimatedDeliveryText String?

  customerAccessToken  String       @unique @default(cuid())

  items                OrderItem[]
  invoices             Invoice[]
  customer             Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([fulfillmentStatus])
  @@index([sourceChannel])
  @@index([paymentGateway])
  @@index([paymentReference])
  @@index([createdAt])
}

model OrderItem {
  id               String    @id @default(cuid())
  orderId          String
  offerId          String?
  title            String
  description      String?
  sku              String?
  partTypeName     String?
  make             String?
  model            String?
  engine           String?
  year             Int?
  quantity         Int       @default(1)
  unitPriceCents   Int
  lineTotalCents   Int
  notes            String?
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([orderId])
  @@index([offerId])
  @@index([partTypeName])
}

model Invoice {
  id                 String        @id @default(cuid())
  invoiceNumber      String        @unique
  customerId         String
  orderId            String?
  status             String        @default("draft") // draft | sent | paid | overdue | void
  currency           String        @default("CAD")
  subtotalCents      Int           @default(0)
  taxCents           Int           @default(0)
  shippingCents      Int           @default(0)
  discountCents      Int           @default(0)
  totalCents         Int           @default(0)
  dueDate            DateTime?
  paidAt             DateTime?
  notes              String?
  pdfUrl             String?
  paymentGateway     String?
  paymentReference   String?
  emailSentAt        DateTime?
  transactionId      String?

  customerAccessToken String       @unique @default(cuid())

  customer           Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order              Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  items              InvoiceItem[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([invoiceNumber])
  @@index([paymentGateway])
  @@index([paymentReference])
  @@index([createdAt])
}

model InvoiceItem {
  id               String    @id @default(cuid())
  invoiceId        String
  title            String
  description      String?
  quantity         Int       @default(1)
  unitPriceCents   Int
  lineTotalCents   Int
  invoice          Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([invoiceId])
}

model Conversation {
  id               String                 @id @default(cuid())
  customerId       String?
  channel          String                 // whatsapp | instagram | facebook | website
  externalThreadId String?
  status           String                 @default("open") // open | pending | closed
  assignedTo       String?
  lastMessageAt    DateTime?
  notes            String?
  customer         Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages         ConversationMessage[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([customerId])
  @@index([channel])
  @@index([status])
  @@index([lastMessageAt])
  @@index([externalThreadId])
}

model ConversationMessage {
  id               String        @id @default(cuid())
  conversationId   String
  direction        String        // inbound | outbound
  senderName       String?
  senderHandle     String?
  messageType      String        @default("text") // text | image | file | system
  content          String?
  automationRuleId String?
  sentAt           DateTime?
  conversation     Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())

  @@index([conversationId])
  @@index([direction])
  @@index([sentAt])
}

model AutoReplyRule {
  id               String    @id @default(cuid())
  name             String
  channel          String    // whatsapp | instagram | facebook | website | all
  triggerType      String    // welcome | after_hours | keyword | invoice_reminder | quote_request
  triggerValue     String?
  replyTemplate    String
  isActive         Boolean   @default(true)
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([channel])
  @@index([triggerType])
  @@index([isActive])
}

model BusinessSetting {
  id                    String    @id @default(cuid())
  businessName          String     @default("Lare Auto")
  businessEmail         String?
  businessPhone         String?
  whatsappNumber        String?
  instagramHandle       String?
  facebookPage          String?
  invoicePrefix         String     @default("INV")
  quotePrefix           String     @default("QTE")
  defaultTaxPercent     Float      @default(13)
  currency              String     @default("CAD")
  afterHoursReply       String?
  welcomeReply          String?
  invoiceReminderReply  String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}
