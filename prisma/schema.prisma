generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SocialPlatform {
  FACEBOOK
  INSTAGRAM
  TIKTOK
}

enum SocialConnectionType {
  MANUAL
  OAUTH
}

enum SocialPostStatus {
  DRAFT
  READY
  PUBLISHED
  FAILED
}

enum SocialPostType {
  IMAGE
  VIDEO
  TEXT
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model Make {
  id        String    @id @default(cuid())
  name      String    @unique
  models    Model[]
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())
}

model Model {
  id        String    @id @default(cuid())
  name      String
  makeId    String
  make      Make      @relation(fields: [makeId], references: [id], onDelete: Cascade)
  engines   Engine[]
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())

  @@unique([makeId, name])
  @@index([makeId])
}

model Engine {
  id        String    @id @default(cuid())
  name      String
  modelId   String
  model     Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())

  @@unique([modelId, name])
  @@index([modelId])
}

model Vehicle {
  id       String @id @default(cuid())
  makeId   String
  modelId  String
  engineId String
  year     Int

  make   Make   @relation(fields: [makeId], references: [id], onDelete: Cascade)
  model  Model  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  engine Engine @relation(fields: [engineId], references: [id], onDelete: Cascade)

  offers           Offer[]
  vehiclePartTypes VehiclePartType[]
  createdAt        DateTime          @default(now())

  @@unique([makeId, modelId, engineId, year])
  @@index([makeId])
  @@index([modelId])
  @@index([engineId])
  @@index([year])
  @@index([makeId, modelId, engineId, year])
}

model PartType {
  id        String            @id @default(cuid())
  name      String            @unique
  parts     Part[]
  fitments  VehiclePartType[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model VehiclePartType {
  id         String   @id @default(cuid())
  vehicleId  String
  partTypeId String
  createdAt  DateTime @default(now())

  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  partType PartType @relation(fields: [partTypeId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, partTypeId])
  @@index([vehicleId])
  @@index([partTypeId])
}

model Part {
  id          String   @id @default(cuid())
  partTypeId  String
  title       String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  partType PartType @relation(fields: [partTypeId], references: [id], onDelete: Restrict)
  offers   Offer[]

  @@index([partTypeId])
}

model Offer {
  id        String @id @default(cuid())
  vehicleId String
  partId    String

  sourceId       String
  sourceSku      String?
  inventoryQty   Int
  costPriceCents Int

  referencePriceCents Int?
  sellPriceCents      Int

  amazonPriceCents   Int?
  aPremiumPriceCents Int?

  amazonUrl   String?
  aPremiumUrl String?

  syncStatus      String?
  syncError       String?
  lastPriceSyncAt DateTime?

  currency     String   @default("CAD")
  leadTimeDays Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  candidates        VendorCandidate[]
  scrapedProducts   OfferScrapedProduct[]
  vehicle           Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  part              Part              @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([partId])
  @@index([sourceId])
  @@index([syncStatus])
}

model VendorCandidate {
  id         String   @id @default(cuid())
  offerId    String
  vendor     String
  title      String
  productUrl String
  priceCents Int?
  badge      String?
  inStock    Boolean?
  score      Int      @default(0)
  selected   Boolean  @default(false)
  rawText    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  scrapedProductId String?
  scrapedProduct   ScrapedProduct? @relation(fields: [scrapedProductId], references: [id], onDelete: SetNull)
  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId])
  @@index([vendor])
  @@index([score])
}

model Quote {
  id             String  @id @default(cuid())
  make           String
  model          String
  engine         String
  year           Int
  partType       String
  vin            String?
  bestOfferId    String?
  itemPriceCents Int

  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  sourceChannel String?
  campaignId    String?

  createdAt DateTime @default(now())

  @@index([utmSource])
  @@index([utmMedium])
  @@index([utmCampaign])
  @@index([sourceChannel])
  @@index([campaignId])
}

model AdminUser {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String?
  isActive     Boolean        @default(true)
  sessions     AdminSession[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model AdminSession {
  id          String    @id @default(cuid())
  token       String    @unique
  adminUserId String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
}

model Customer {
  id                        String         @id @default(cuid())
  firstName                 String
  lastName                  String?
  email                     String?
  phone                     String?
  whatsappNumber            String?
  companyName               String?
  notes                     String?
  addressLine1              String?
  addressLine2              String?
  city                      String?
  province                  String?
  postalCode                String?
  country                   String?        @default("Canada")
  isActive                  Boolean        @default(true)
  orders                    Order[]
  invoices                  Invoice[]
  conversations             Conversation[]
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  convertedWorkshopLead     WorkshopLead?  @relation("WorkshopLeadCustomer")
  isMechanicEligible        Boolean        @default(false)
  mechanicEligibleAt        DateTime?
  mechanicInviteSentAt      DateTime?
  mechanicInviteToken       String?        @unique
  mechanicInviteExpiresAt   DateTime?
  mechanicSignupCompletedAt DateTime?
  quoteLeads                QuoteLead[]
  preferredReplyChannel     String?
  customerType              String? // retail | mechanic_prospect | approved_mechanic

  @@index([email])
  @@index([phone])
  @@index([whatsappNumber])
  @@index([firstName])
  @@index([postalCode])
}

model Order {
  id                    String                @id @default(cuid())
  orderNumber           String                @unique
  customerId            String
  quoteId               String?
  status                String                @default("draft")
  paymentStatus         String                @default("pending")
  fulfillmentStatus     String                @default("unfulfilled")
  deliveryStatus        String                @default("pending")
  currency              String                @default("CAD")
  subtotalCents         Int                   @default(0)
  taxCents              Int                   @default(0)
  shippingCents         Int                   @default(0)
  discountCents         Int                   @default(0)
  totalCents            Int                   @default(0)
  internalNotes         String?
  customerNotes         String?
  sourceChannel         String?
  deliveryChargeCents   Int                   @default(0)
  taxPercentApplied     Float                 @default(13)
  paymentGateway        String?
  paymentReference      String?
  paidAt                DateTime?
  billingEmail          String?
  addressLine1          String?
  addressLine2          String?
  city                  String?
  province              String?
  postalCode            String?
  country               String?               @default("Canada")
  estimatedDeliveryText String?
  mechanicId            String?
  mechanic              Mechanic?             @relation("MechanicDirectOrders", fields: [mechanicId], references: [id], onDelete: SetNull)
  mechanicReferralCode  String?
  orderPlacedByType     String?
  mechanicDiscountCents Int                   @default(0)
  referralCodeId        String?
  referredByMechanicId  String?
  mechanicCreditCents   Int                   @default(0)
  referredByMechanic    Mechanic?             @relation("ReferredOrders", fields: [referredByMechanicId], references: [id], onDelete: SetNull)
  referralCode          MechanicReferralCode? @relation(fields: [referralCodeId], references: [id], onDelete: SetNull)
  referralDiscountCents Int                   @default(0)
  customerAccessToken   String?               @unique
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  campaignId            String?
  items                 OrderItem[]
  invoices              Invoice[]
  customer              Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  mechanicCommissions   MechanicCommission[]
  quoteLeads            QuoteLead[]

  inventoryStatus       String    @default("inventory_check_pending")
  inventoryCheckedAt    DateTime?
  inventoryCheckedBy    String?
  inventoryNotes        String?
  supplierName          String?
  supplierReference     String?
  preferredReplyChannel String?
  lastCustomerChannel   String?
  inventoryUpdatedAt    DateTime?
  customerType          String?

  deliveryNotes     String?
  courierName       String?
  trackingReference String?
  dispatchedAt      DateTime?
  deliveredAt       DateTime?
  deliveryUpdatedAt DateTime?

  vendorCostCents    Int     @default(0)
  transportCostCents Int     @default(0)
  packagingCostCents Int     @default(0)
  vendorInvoiceRef   String?
  payoutNotes        String?

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([fulfillmentStatus])
  @@index([deliveryStatus])
  @@index([sourceChannel])
  @@index([paymentGateway])
  @@index([paymentReference])
  @@index([createdAt])
  @@index([mechanicId])
  @@index([mechanicReferralCode])
  @@index([orderPlacedByType])
  @@index([referralCodeId])
  @@index([referredByMechanicId])
  @@index([utmSource])
  @@index([utmMedium])
  @@index([utmCampaign])
  @@index([campaignId])
  @@index([inventoryStatus])
  @@index([supplierName])
  @@index([preferredReplyChannel])
  @@index([customerType])
  @@index([courierName])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  offerId        String?
  title          String
  description    String?
  sku            String?
  partTypeName   String?
  make           String?
  model          String?
  engine         String?
  year           Int?
  quantity       Int      @default(1)
  unitPriceCents Int
  lineTotalCents Int
  notes          String?
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderId])
  @@index([offerId])
  @@index([partTypeName])
}

model Invoice {
  id                  String    @id @default(cuid())
  invoiceNumber       String    @unique
  customerId          String
  orderId             String?
  status              String    @default("draft")
  currency            String    @default("CAD")
  subtotalCents       Int       @default(0)
  taxCents            Int       @default(0)
  shippingCents       Int       @default(0)
  discountCents       Int       @default(0)
  totalCents          Int       @default(0)
  dueDate             DateTime?
  paidAt              DateTime?
  notes               String?
  pdfUrl              String?
  paymentGateway      String?
  paymentReference    String?
  emailSentAt         DateTime?
  transactionId       String?
  customerAccessToken String?   @unique

  customer  Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order     Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  items     InvoiceItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@index([invoiceNumber])
  @@index([paymentGateway])
  @@index([paymentReference])
  @@index([createdAt])
}

model InvoiceItem {
  id             String   @id @default(cuid())
  invoiceId      String
  title          String
  description    String?
  quantity       Int      @default(1)
  unitPriceCents Int
  lineTotalCents Int
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([invoiceId])
}

model Conversation {
  id               String                @id @default(cuid())
  customerId       String?
  channel          String
  externalThreadId String?
  status           String                @default("open")
  assignedTo       String?
  lastMessageAt    DateTime?
  notes            String?
  customer         Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages         ConversationMessage[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([customerId])
  @@index([channel])
  @@index([status])
  @@index([lastMessageAt])
  @@index([externalThreadId])
}

model ConversationMessage {
  id               String       @id @default(cuid())
  conversationId   String
  direction        String
  senderName       String?
  senderHandle     String?
  messageType      String       @default("text")
  content          String?
  automationRuleId String?
  sentAt           DateTime?
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())

  @@index([conversationId])
  @@index([direction])
  @@index([sentAt])
}

model AutoReplyRule {
  id            String   @id @default(cuid())
  name          String
  channel       String
  triggerType   String
  triggerValue  String?
  replyTemplate String
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([channel])
  @@index([triggerType])
  @@index([isActive])
}

model BusinessSetting {
  id                   String   @id @default(cuid())
  businessName         String   @default("Lare Auto")
  businessEmail        String?
  businessPhone        String?
  whatsappNumber       String?
  instagramHandle      String?
  facebookPage         String?
  invoicePrefix        String   @default("INV")
  quotePrefix          String   @default("QTE")
  defaultTaxPercent    Float    @default(13)
  currency             String   @default("CAD")
  afterHoursReply      String?
  welcomeReply         String?
  invoiceReminderReply String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Mechanic {
  id                  String                 @id @default(cuid())
  shopName            String
  contactName         String
  email               String                 @unique
  phone               String?
  passwordHash        String
  isApproved          Boolean                @default(false)
  isActive            Boolean                @default(true)
  tradeDiscountPct    Float                  @default(10)
  referralDiscountPct Float                  @default(2)
  creditBalanceCents  Int                    @default(0)
  notes               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  commissions         MechanicCommission[]
  sessions            MechanicSession[]
  referralCodes       MechanicReferralCode[]
  directOrders        Order[]                @relation("MechanicDirectOrders")
  referredOrders      Order[]                @relation("ReferredOrders")

  @@index([email])
  @@index([shopName])
  @@index([isApproved])
  @@index([isActive])
}

model MechanicSession {
  id         String   @id @default(cuid())
  token      String   @unique
  mechanicId String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  mechanic Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)

  @@index([mechanicId])
  @@index([expiresAt])
}

model MechanicReferralCode {
  id                  String    @id @default(cuid())
  mechanicId          String
  code                String    @unique
  isActive            Boolean   @default(true)
  expiresAt           DateTime?
  usageLimit          Int?      @default(1)
  usedCount           Int       @default(0)
  customerDiscountPct Float     @default(2)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  mechanic Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([mechanicId])
  @@index([code])
  @@index([isActive])
  @@index([expiresAt])
}

model SocialChannel {
  id                String               @id @default(cuid())
  platform          SocialPlatform
  displayName       String
  handle            String?
  profileUrl        String
  profileImageUrl   String?
  isActive          Boolean              @default(true)
  connectionType    SocialConnectionType @default(MANUAL)
  externalAccountId String?
  accessTokenEnc    String?
  refreshTokenEnc   String?
  tokenExpiresAt    DateTime?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  posts SocialPost[]

  @@unique([platform, profileUrl])
  @@index([platform])
  @@index([isActive])
}

model SocialPost {
  id             String           @id @default(cuid())
  channelId      String
  campaignId     String?
  title          String
  caption        String
  mediaUrl       String?
  targetUrl      String?
  postType       SocialPostType   @default(IMAGE)
  status         SocialPostStatus @default(DRAFT)
  scheduledAt    DateTime?
  publishedAt    DateTime?
  externalPostId String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  channel  SocialChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  campaign Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([channelId])
  @@index([campaignId])
  @@index([status])
  @@index([postType])
  @@index([scheduledAt])
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  objective   String?
  platform    String?
  audience    String?
  landingUrl  String
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  status      CampaignStatus @default(DRAFT)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  posts SocialPost[]

  @@index([status])
  @@index([platform])
}

model WorkshopLead {
  id                    String                   @id @default(cuid())
  shopName              String
  contactName           String?
  phone                 String?
  whatsappNumber        String?
  email                 String?
  website               String?
  addressLine1          String?
  city                  String?
  province              String?
  postalCode            String?
  googleMapsUrl         String?
  category              String?
  rating                Float?
  reviewCount           Int?
  source                String? // yellowpages | yelp | google | manual | csv
  status                String                   @default("new") // new | reviewed | approved | rejected | contacted | replied | converted
  notes                 String?
  scrapedAt             DateTime?

  scrapePlatform        String?
  scrapeQuery           String?
  contactQuality        String? // high | medium | low
  leadScore             Int?
  phoneSource           String? // direct | directory | social | unknown
  isVirtualPhone        Boolean?
  outreachGoal          String?
  adminNotes            String?

  customerId            String?                  @unique
  convertedAt           DateTime?
  conversionNote        String?
  estimatedMonthlyValue Float?
  customer              Customer?                @relation("WorkshopLeadCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  inboundMessages       OutreachInboundMessage[]
  replySession          OutreachReplySession?
  messages              OutreachMessage[]
  followUps             OutreachLeadFollowUp[]
  bestContactChannel    String?   // whatsapp | call | email | social | mixed
  isWhatsappQuality     Boolean    @default(false)
  isCallOnly            Boolean    @default(false)
  isEmailQuality        Boolean    @default(false)
  isSocialOnly          Boolean    @default(false)

  facebookPageUrl       String?
  instagramPageUrl      String?
  hasWhatsappLink       Boolean    @default(false)
  hasMessengerLink      Boolean    @default(false)
  websiteContactUrl     String?

authenticityTier      String?   // high | medium | low
  @@index([shopName])
  @@index([city])
  @@index([province])
  @@index([status])
  @@index([source])
  @@index([scrapePlatform])
  @@index([contactQuality])
  @@index([leadScore])
  @@index([bestContactChannel])
  @@index([isWhatsappQuality])
  @@index([isCallOnly])
  @@index([isEmailQuality])
  @@index([isSocialOnly])
  @@index([authenticityTier])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  channel   String // whatsapp | sms | email
  audience  String? // workshop | mechanic | retail
  subject   String?
  body      String
  mediaUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns OutreachCampaign[]

  @@index([channel])
  @@index([audience])
  @@index([isActive])
}

model OutreachCampaign {
  id               String   @id @default(cuid())
  name             String
  channel          String // whatsapp | sms | email
  audience         String? // workshop | mechanic | retail
  templateId       String?
  status           String   @default("draft") // draft | active | paused | completed
  dailyLimit       Int      @default(25)
  totalRecipients  Int      @default(0)
  sentCount        Int      @default(0)
  failedCount      Int      @default(0)
  repliedCount     Int      @default(0)
  notes            String?
  filterCity       String?
  filterSource     String?
  filterLeadStatus String?  @default("approved")
  requireWhatsapp  Boolean  @default(false)
  requireEmail     Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  template MessageTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  messages OutreachMessage[]

  @@index([channel])
  @@index([status])
  @@index([templateId])
}

model OutreachMessage {
  id                String    @id @default(cuid())
  campaignId        String
  workshopLeadId    String?
  channel           String // whatsapp | sms | email
  recipientName     String?
  recipientPhone    String?
  recipientEmail    String?
  bodySnapshot      String
  mediaUrl          String?
  sendStatus        String    @default("pending") // pending | sent | failed | delivered | replied
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  repliedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  campaign        OutreachCampaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  workshopLead    WorkshopLead?            @relation(fields: [workshopLeadId], references: [id], onDelete: SetNull)
  inboundMessages OutreachInboundMessage[]

  @@index([campaignId])
  @@index([workshopLeadId])
  @@index([channel])
  @@index([sendStatus])
  @@index([sentAt])
}

model OutreachInboundMessage {
  id                String   @id @default(cuid())
  outreachMessageId String?
  workshopLeadId    String?
  channel           String
  fromNumber        String?
  body              String
  providerMessageId String?
  createdAt         DateTime @default(now())

  outreachMessage OutreachMessage? @relation(fields: [outreachMessageId], references: [id], onDelete: SetNull)
  workshopLead    WorkshopLead?    @relation(fields: [workshopLeadId], references: [id], onDelete: SetNull)

  @@index([outreachMessageId])
  @@index([workshopLeadId])
  @@index([channel])
  @@index([fromNumber])
}

model OutreachReplySession {
  id             String    @id @default(cuid())
  workshopLeadId String    @unique
  channel        String
  lastOutboundId String?
  partType       String?
  year           Int?
  make           String?
  model          String?
  engine         String?
  status         String    @default("open")
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workshopLead WorkshopLead @relation(fields: [workshopLeadId], references: [id], onDelete: Cascade)

  @@index([channel])
  @@index([status])
}

model OutreachLeadFollowUp {
  id             String    @id @default(cuid())
  workshopLeadId String
  note           String
  followUpAt     DateTime?
  status         String    @default("open") // open | done | cancelled
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workshopLead WorkshopLead @relation(fields: [workshopLeadId], references: [id], onDelete: Cascade)

  @@index([workshopLeadId])
  @@index([status])
  @@index([followUpAt])
}

model MechanicCommission {
  id          String    @id @default(cuid())
  mechanicId  String
  orderId     String
  type        String    @default("referral") // referral
  amountCents Int
  status      String    @default("pending") // pending | paid | cancelled
  earnedAt    DateTime  @default(now())
  paidAt      DateTime?
  payoutNote  String?

  mechanic Mechanic @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([mechanicId, orderId, type])
  @@index([mechanicId])
  @@index([orderId])
  @@index([status])
  @@index([earnedAt])
}

model QuoteLead {
  id             String  @id @default(cuid())
  quoteId        String?
  offerId        String?
  firstName      String?
  lastName       String?
  email          String?
  phone          String?
  whatsappNumber String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  province       String?
  postalCode     String?
  country        String? @default("Canada")

  year           Int?
  make           String?
  model          String?
  engine         String?
  partType       String?
  vin            String?
  itemPriceCents Int?    @default(0)

  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  sourceChannel String?
  status        String  @default("quote_viewed") // quote_viewed | checkout_started | contact_captured | ordered | paid | abandoned

  customerId            String?
  orderId               String?
  preferredReplyChannel String?
  lastInboundChannel    String?
  lastOutboundChannel   String?
  quoteLinkSentAt       DateTime?
  inventoryUpdatedAt    DateTime?
  customerType          String? // retail | mechanic_prospect | approved_mechanic
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  customer              Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order                 Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  inventoryStatus       String    @default("inventory_check_pending")
  inventoryCheckedAt    DateTime?
  inventoryNotes        String?
  readyToOrderAt        DateTime?
  checkoutLinkSentAt    DateTime?
  customerAccessToken   String?   @unique

  @@index([quoteId])
  @@index([offerId])
  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([utmSource])
  @@index([utmCampaign])
  @@index([sourceChannel])
  @@index([preferredReplyChannel])
  @@index([customerType])
  @@index([inventoryStatus])
}

model ScrapedProduct {
  id                    String   @id @default(cuid())
  vendor                String   // amazon
  asin                  String?
  productUrl            String   @unique
  canonicalKey          String?  @unique
  title                 String
  rawText               String?
  sellerStore           String?
  preferredSupplier     Boolean  @default(false)

  priceCents            Int?
  currency              String   @default("CAD")
  inStock               Boolean?
  inventoryCount        Int?
  inventoryText         String?

  fitmentConfirmed      Boolean?
  cannotConfirmFit      Boolean?

  referenceNumbers      String[] @default([])
  lastScrapedAt         DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  fitments              ScrapedProductFitment[]
  candidates            VendorCandidate[]
  offerAssignments      OfferScrapedProduct[]

  @@index([vendor])
  @@index([asin])
  @@index([preferredSupplier])
  @@index([priceCents])
  @@index([lastScrapedAt])
}

model ScrapedProductFitment {
  id               String   @id @default(cuid())
  scrapedProductId String

  make             String
  model            String
  engine           String?
  yearFrom         Int?
  yearTo           Int?
  rawFitmentText   String?

  scrapedProduct   ScrapedProduct @relation(fields: [scrapedProductId], references: [id], onDelete: Cascade)

  @@index([scrapedProductId])
  @@index([make])
  @@index([model])
  @@index([engine])
  @@index([yearFrom, yearTo])
}

model OfferScrapedProduct {
  id               String   @id @default(cuid())
  offerId          String
  scrapedProductId String

  matchSource      String?  // exact_reference | parsed_fitment | manual_selected
  score            Int      @default(0)
  selected         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  offer            Offer          @relation(fields: [offerId], references: [id], onDelete: Cascade)
  scrapedProduct   ScrapedProduct @relation(fields: [scrapedProductId], references: [id], onDelete: Cascade)

  @@unique([offerId, scrapedProductId])
  @@index([offerId])
  @@index([scrapedProductId])
  @@index([selected])
  @@index([score])
}