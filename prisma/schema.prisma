generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Make {
  id        String   @id @default(cuid())
  name      String   @unique
  models    Model[]
  vehicles  Vehicle[]
  createdAt DateTime @default(now())
}

model Model {
  id        String   @id @default(cuid())
  name      String
  makeId    String
  make      Make     @relation(fields: [makeId], references: [id], onDelete: Cascade)
  engines   Engine[]
  vehicles  Vehicle[]
  createdAt DateTime @default(now())

  @@unique([makeId, name])
  @@index([makeId])
}

model Engine {
  id        String    @id @default(cuid())
  name      String
  modelId    String
  model     Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())

  @@unique([modelId, name])
  @@index([modelId])
}

model Vehicle {
  id         String   @id @default(cuid())
  makeId      String
  modelId     String
  engineId    String
  year        Int

  make       Make     @relation(fields: [makeId], references: [id], onDelete: Cascade)
  model      Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  engine     Engine   @relation(fields: [engineId], references: [id], onDelete: Cascade)

  offers     Offer[]
  createdAt  DateTime @default(now())

  @@unique([makeId, modelId, engineId, year])
  @@index([makeId, modelId, engineId, year])
}

model Part {
  id          String   @id @default(cuid())
  partType    String
  title       String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offers      Offer[]

  @@index([partType])
}

model Offer {
  id                  String   @id @default(cuid())
  vehicleId           String
  partId              String

  sourceId            String   // internal only: "manual", "distA", "distB"
  sourceSku           String?
  inventoryQty        Int
  costPriceCents      Int

  referencePriceCents Int?     // final chosen vendor reference price
  sellPriceCents      Int      // customer-facing item price

  amazonPriceCents    Int?
  aPremiumPriceCents  Int?

  amazonUrl           String?
  aPremiumUrl         String?

  syncStatus          String?  // "success", "failed", "partial"
  syncError           String?
  lastPriceSyncAt     DateTime?

  currency            String   @default("CAD")
  leadTimeDays        Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  vehicle             Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  part                Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([partId])
  @@index([sourceId])
  @@index([syncStatus])
}

model Quote {
  id             String   @id @default(cuid())
  make           String
  model          String
  engine         String
  year           Int
  partType       String
  vin            String?
  bestOfferId    String?
  itemPriceCents Int
  createdAt      DateTime @default(now())
}